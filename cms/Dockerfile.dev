FROM node:20-alpine

WORKDIR /app

# Install development tools
RUN apk add --no-cache \
    vips-dev \
    curl \
    vim \
    git

# Copy package files
COPY package.json package-lock.json ./

# Install all dependencies
RUN npm install

# Copy source code
COPY . .

# Create uploads directory
RUN mkdir -p public/uploads

# Expose port
EXPOSE 1337

# Run in development mode
CMD ["npm", "run", "develop"]